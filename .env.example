# Copia este archivo a .env y ajusta valores. NO se versiona (salvo este ejemplo).
# El compose pasa TODO .env al contenedor (env_file), así que puedes agregar
# cualquier clave HERMES_CFG__* / HERMES_ENV__* sin tocar docker-compose.yaml.

# ---- Webtop (escritorio por navegador) ----
TZ=America/Santiago
TITLE=Hermes Agent
CUSTOM_USER=tu_usuario
PASSWORD=cambia_esto

# =============================================================================
# PROVIDER DE MODELO  (100% agnóstico — elige UNO, descomenta su bloque)
# =============================================================================
# Convenciones:
#   HERMES_CFG__<seccion>__<clave>  ->  config.yaml  ( "__" = "." )
#   HERMES_ENV__<CLAVE>             ->  CLAVE=valor en el .env de Hermes (keys)
# base_url SIEMPRE vía HERMES_CFG__model__base_url (config.yaml) — funciona para
# todos los providers. NO uses los *_BASE_URL específicos (LM_BASE_URL, etc.):
# son redundantes y atan la config a un provider.
# context_length lo fija el provisioning en 65536 si lo omites (Hermes exige ≥64K).

# ---- LM Studio (LOCAL, gratis, sin API key) ---------------------------------
# Endpoint debe terminar en /v1. Desde el contenedor, 127.0.0.1 ≠ host: usa la
# IP LAN de la máquina que corre LM Studio (ej. http://192.168.1.18:1234/v1).
HERMES_CFG__model__provider=lmstudio
HERMES_CFG__model__default=google/gemma-4-e4b
HERMES_CFG__model__base_url=http://127.0.0.1:1234/v1
HERMES_ENV__LM_API_KEY=lm-studio            # LM Studio acepta cualquier valor

# ---- Ollama (LOCAL, gratis, sin API key) ------------------------------------
# HERMES_CFG__model__provider=ollama
# HERMES_CFG__model__default=llama3.1
# HERMES_CFG__model__base_url=http://127.0.0.1:11434/v1   # endpoint OpenAI-compat de Ollama

# ---- Claude / Anthropic (API key de pago) -----------------------------------
# HERMES_CFG__model__provider=anthropic
# HERMES_CFG__model__default=claude-sonnet-4-6
# HERMES_ENV__ANTHROPIC_API_KEY=sk-ant-...

# ---- OpenAI (API key de pago) -----------------------------------------------
# OJO: provider=openai se rutea a OpenRouter. Para OpenAI DIRECTO usa openai-api.
# HERMES_CFG__model__provider=openai-api
# HERMES_CFG__model__default=gpt-5.1
# HERMES_ENV__OPENAI_API_KEY=sk-...

# ---- MiniMax (API key de pago) ----------------------------------------------
# HERMES_CFG__model__provider=minimax
# HERMES_CFG__model__default=minimax-m3
# HERMES_ENV__MINIMAX_API_KEY=...

# =============================================================================
# GATEWAYS DE MENSAJERÍA  (opcionales)
# =============================================================================
# Telegram (gratuito; bot propio de @BotFather).
HERMES_ENV__TELEGRAM_BOT_TOKEN=123456:ABC...
HERMES_ENV__TELEGRAM_ALLOWED_USERS=          # IDs separados por coma
HERMES_ENV__TELEGRAM_HOME_CHANNEL=           # recomendado: chat home; si hay un solo allowed user, se infiere

# ---- Computer use (cua-driver, gratuito) --------------------------------
# 1 = instala cua-driver y habilita control del escritorio XFCE.
HERMES_COMPUTER_USE=0

# ---- Display para computer use (opcional) -------------------------------
# El gateway corre detachado de la sesión gráfica; estos apuntan al display de
# webtop. Defaults: :1 y /run/user/1000. Descomenta solo si tu webtop difiere.
# DISPLAY=:1
# XDG_RUNTIME_DIR=/run/user/1000
